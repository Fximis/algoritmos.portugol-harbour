Algoritmo "EXC04L03"
//
//
// Descriïŋ―ïŋ―o   : Solicite uma string e exiba-a totalmente em minïŋ―sculas.
// Autor(a)    : Fellipe Miquelïŋ―o Schmidt 
// Data atual  : 26/08/2025
Var

   palavra: caractere

Inicio


      escreva ("Digite algo: ")
      leia (palavra)

      escreval (minusc(palavra))





Fimalgoritmo