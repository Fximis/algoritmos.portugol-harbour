Algoritmo "EXC18L03"
//
//
// Descriï¿½ï¿½o   : Gere uma sequï¿½ncia aleatï¿½ria contendo: 4 vogais minï¿½sculas, 2 vogais maiï¿½sculas, 3 consoantes maiï¿½sculas e 3 nï¿½meros.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var

   vMin, vMai, num, con, seq, seqrand: caractere
   posicao, i: inteiro


Inicio

   vMin := "aeiou"
   num := "0123456789"
   con := "BCDFGHJKLMNPQRSTVWXYZ"

   //4 Vogais minï¿½sculas
   para i de 1 ate 4 faca
      posicao := randi(5) + 1
      seq := seq + (copia(vMin,posicao,1))
   fimpara
   
   //2 Vogais maiï¿½sculas
   para i de 1 ate 2 faca
      posicao := randi(5) + 1
      seq := seq + maiusc(copia(vMin,posicao,1))
   fimpara
   
   //3 Consoantes maiï¿½sculas
   para i de 1 ate 3 faca
      posicao := randi(21) + 1
      seq := seq + (copia(con,posicao,1))
   fimpara
   
   //3 Numeros
   para i de 1 ate 3 faca
      posicao := randi(10) + 1
      seq := seq + (copia(num,posicao,1))
   fimpara
   
   // Para conferir se seqrand esta com a sequencia de seq -> escreval (seq)  nessa posiï¿½ï¿½o

   // Gerar a sequencia aleatï¿½ria da string, com os os caracteres que foram gerados acima, sem repetir
   para i de 1 ate compr(seq) faca
      posicao := randi(compr(seq))
      seqrand := seqrand + (copia(seq,posicao,1))
      // faz a exclusï¿½o do caractere que foi selecionado (seq recebe atï¿½ uma posicao anterior e pega o resto da posterior)
      se (posicao > 1) entao
         seq := copia(seq, 1, posicao -1) + copia(seq, posicao +1, compr(seq)-posicao)
      senao
      //faz a exclusï¿½o do primeiro caractere, caso seja selecionado
         seq := copia(seq, 2,compr(seq)-1)
      fimse
   fimpara

   escreva (seqrand)
Fimalgoritmo