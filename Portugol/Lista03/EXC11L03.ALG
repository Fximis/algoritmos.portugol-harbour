Algoritmo "EXC11L03"
//
//
// Descriï¿½ï¿½o   : Solicite um nï¿½mero no formato string e verifique se contï¿½m apenas dï¿½gitos numï¿½ricos.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
Var

   numero, verificador : caractere
   i, x: inteiro

Inicio


   escreval("Digite um nï¿½mero em formato de string: ")
   leia (numero)

   x := compr(numero)

   para i de 1 ate compr(numero) faca
      verificador := copia(numero,i,1)

      se (asc(verificador) >= 048) e (asc(verificador)<= 057) entao
         escreval (verificador, " ï¿½ um nï¿½mero ")
      senao
         escreval (verificador, " nï¿½o ï¿½ um nï¿½mero")
      fimse
   fimpara



Fimalgoritmo