Algoritmo "EXC19L03"
//
//
// Descriï¿½ï¿½o   : Apresente o valor ASCII de todas as letras (maiï¿½sculas e minï¿½sculas) e todos os nï¿½meros.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var

   valor: caracter
   tabela,i: inteiro

Inicio
   i := 0
   escreval ("Valor ASCII para letras maiï¿½sculas: ")

   para i de 0 ate 25 passo 1 faca

      valor := (carac(65+i))
      tabela := asc(valor)

      escreval (valor, " - ",tabela)
   fimpara
   
   escreval (" ")
   
   i := 0
   escreval ("Valor ASCII para letras minï¿½sculas: ")

   para i de 0 ate 25 passo 1 faca

      valor := (carac(97+i))
      tabela := asc(valor)

      escreval (valor, " - ",tabela)
   fimpara






Fimalgoritmo