Algoritmo "EXC35L03"
//
//
// Descriï¿½ï¿½o   : Solicite uma frase (mï¿½nimo 8 caracteres) e apresente se a mesma ï¿½ ou nï¿½o um palï¿½ndromo. Obs. Deve haver ao menos um espaï¿½o na frase.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var

   palavra,x,y,px,py: caractere
   i, verif, verifasc: inteiro

Inicio

   enquanto (compr(palavra) < 8) e (verifasc <> 32) faca

      escreva("Digite uma palavra: ")
      leia(palavra)

      x := (copia(palavra,i,1))
      verif := asc(x)

      se (verif = 32) entao
         verifasc := 32
      fimse

   fimenquanto

   para i de 1 ate compr(palavra) passo 1 faca
      x := (copia(palavra,i,1))
      px := px+x
   fimpara

   para i de compr(palavra)ate 1 passo -1 faca
      y := (copia(palavra,i,1))
      py:=py+y
   fimpara

   se (px=py) entao
      escreval ("ï¿½ um palindromo")
   senao
      escreval ("nï¿½o ï¿½ um palï¿½ndromo")
   fimse

Fimalgoritmo