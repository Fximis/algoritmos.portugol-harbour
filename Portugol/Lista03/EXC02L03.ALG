Algoritmo "EXC02L03"
//
//
// Descriï¿½ï¿½o   : Solicite uma string (palavra ou frase) e exiba a quantidade de caracteres que ela contï¿½m.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var

   palavra, car: caractere
   contador: inteiro


Inicio


   repita
      escreva ("Digite uma palavra com mï¿½n. de 5 caracteres: ")
      leia (palavra)
      contador := compr(palavra)
   ate (contador >= 5)




Fimalgoritmo