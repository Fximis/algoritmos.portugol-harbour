Algoritmo "EXC28L03"
//
//
// Descriï¿½ï¿½o   : Solicite duas strings e informe se sï¿½o iguais considerando que maiï¿½sculos sï¿½o distintos de minï¿½sculos
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var

   string1, string2, s, y: caractere
   i: inteiro

Inicio

   escreval ("Verificador de igualdade")
   escreval (" ")
   escreva ("Digite uma string: ")
   leia (string1)
   escreva("Digite outra string: ")
   leia (string2)

   se (compr(string1) = compr(string2))entao
      escreval ("Possuem a mesma quantidade de caractere")
   senao
      escreval ("Nï¿½o sï¿½o iguais, pois, nï¿½o possuem a mesma quantidade de caracteres")
      interrompa
   fimse

   para i de 1 ate compr(string1) faca

      s := (copia(string1,i,1))
      y := (copia(string2,i,1))

      se (s <> y) entao
         escreval ("As strings sï¿½o diferentes ", s, " e ", y, " nï¿½o possuem o mesmo valor")
         interrompa
      fimse
      se (s=y) entao
         escreval (s, " ", y, " sï¿½o caracteres iguais")
      fimse
   fimpara


//Fazer tambï¿½m com se asc >= 97 e <= 122 ////(65-90)//// entao asc := -32/+32 (transformando em maiusc/minusc --> a <> ï¿½ que o valor na exibiï¿½ï¿½o vai aparecer o original A ou a.

Fimalgoritmo