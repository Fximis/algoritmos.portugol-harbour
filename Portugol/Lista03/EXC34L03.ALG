Algoritmo "EXC34L03"
//
//
// Descriï¿½ï¿½o   : Solicite um nï¿½mero inteiro e converta-o em string, depois apresente seus dï¿½gitos ao contrï¿½rio.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/09/2025
Var

   x, s, invert: caracter
   num, i: inteiro

Inicio

   i:= 0

   escreval ("Digite um nï¿½mero inteiro")
   leia (num)

   x:= numpcarac(num)

   para i de compr(x) ate 1 passo -1 faca

      s := copia(x,i,1)

      invert:= invert + s

   fimpara

   escreva (invert)

Fimalgoritmo