Algoritmo "EXC30L03"
//
//
// Descriï¿½ï¿½o   : Solicite uma string e informe se ela nï¿½o contï¿½m a letra 'Z'.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var
   frase, s : caracter
   i, verifasc: inteiro
   x: logico

Inicio

   x := falso

   escreval ("Digite uma frase:")
   leia (frase)

   para i de 1 ate compr(frase) faca

      s:= copia(frase,i,1)
      verifasc:= asc(s)

      se (verifasc = 90) ou (verifasc = 122) entao
      //se (verifasc = 90) entao
         x:= verdadeiro
      fimse
   fimpara

   se x = falso entao
      escreval (frase, " nï¿½o contï¿½m 'Z'")
   senao
      escreval (frase, " contï¿½m 'Z'")
   fimse


Fimalgoritmo