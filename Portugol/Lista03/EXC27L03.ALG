Algoritmo "EXC27L03"
//
//
// Descriï¿½ï¿½o   : Solicite um nome completo e apresente apenas o ï¿½ltimo sobrenome com todos os caracteres minï¿½sculos.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var
    frase: caracter
    i: inteiro

Inicio
    escreval("Digite o nome completo:")
    leia(frase)

    para i de 1 ate compr(frase) faca
        se (copia(frase, i, 1) = " ") entao
            frase :=  maiusc(copia(frase, 1, i)) + copia(minusc(frase), i + 1, compr(frase) - i)
        fimse
    fimpara

    escreval(frase)

Fimalgoritmo