Algoritmo "EXC08L03"
//
//
// Descriï¿½ï¿½o   : Solicite uma string (mï¿½nimo 4 caracteres) e exiba, para cada caractere, seu valor ASCII.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt
// Data atual  : 26/08/2025
Var

   algo: caractere
   i: inteiro

Inicio

   enquanto (compr(algo) < 4) faca
      escreva ("Digite algo com no mï¿½nimo 4 caracteres: ")
      leia (algo)
   fimenquanto

   para i de 1 ate compr(algo) faca

      escreval ("Caractere: ", copia(algo,i,1), " -- Valor ASCII: ", asc(copia(algo,i,1)))

   fimpara




Fimalgoritmo