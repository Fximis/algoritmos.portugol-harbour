Algoritmo "EXC01L03"
// 
//  
// Descriï¿½ï¿½o   : Solicite uma string (palavra ou frase) e exiba a quantidade de caracteres que ela contï¿½m.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 26/08/2025
Var
frase, palavra: caractere


Inicio

      escreva ("Digite uma palavra: ")
      leia (palavra)

      escreva ("Digite uma frase: ")
      leia (frase)
      
      escreval (" ")

      escreval ("A palavra ", palavra, " possui ",compr(palavra), " caracteres")
      escreval (" ")
      escreval ("A frase ", frase, " possui ", compr(frase), " caracteres")
      

Fimalgoritmo