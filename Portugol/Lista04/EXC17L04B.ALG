Var
   v1: vetor[1..10] de inteiro
   vaux: vetor[1..100] de logico


//FAZER DO 0


//================================================
funcao busca(n:inteiro):inteiro
var
i,p: inteiro

inicio

      p := 0
      para i de 1 ate 10 faca
           se (v[i]=n)entao
              p := i
           fimse
      fimpara
      retorne p

fimfuncao
//==================================================


inicio









Fimalgoritmo