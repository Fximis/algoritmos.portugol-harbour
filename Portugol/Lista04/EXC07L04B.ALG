Algoritmo "EXC07L04B"
//
//
// Descriï¿½ï¿½o   : Solicite ao usuï¿½rio 5 nï¿½meros inteiros, guarde-os em um vetor e em seguida
//apresente-os ao usuï¿½rio. Finalmente, apresente tambï¿½m quantos elementos
//sï¿½o negativos.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt. 
// Data atual  : 10/10/2025

Var
   v: vetor[1..5] de inteiro
   i, cont: inteiro

Inicio
   cont := 0

   escreval ("Digite 05 nï¿½meros inteiros")

   para i de 1 ate 5 faca
      leia (v[i])
   fimpara

   limpatela

   escreva ("os valores apresentados foram: ")
   cont := 0
   para i de 1 ate 5 faca
      escreva (v[i], " ")
      se (v[i]<0) entao
         cont := cont + 1
      fimse
   fimpara
   escreval (" ")
   se (cont>0) entao
      escreva ("houveram", cont, " numeros negativos")
   senao
      escreval ("Nï¿½o houveram valores negativos")
   fimse







Fimalgoritmo