Algoritmo "exc15L01"
// 
//  
// Faï¿½a o mesmo exercï¿½cio anterior sem utilizar uma terceira variï¿½vel.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
valorUm, valorDois, subtracao, resultado: real


Inicio
      Escreva ("Digite o primeiro valor: ")
      Leia (valorUm)
      
      Escreva ("Digite o segundo valor: ")
      Leia (valorDois)
      
      subtracao <- (valorUm - valorDois)
      

      resultado <- (valorUm - ValorDois) * 0.1
      
      Escreval ("Realizando", valorUm, " - ", valorDois, " temos", subtracao, " sendo a dï¿½cima parte", resultado)


Fimalgoritmo