Algoritmo "Ex01NomeSalario"
// 
//  
// Descriï¿½ï¿½o   : Solicite o nome e o salï¿½rio de uma pessoa. Calcule e apresente o novo salï¿½rio com um aumento de 28,5%
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
   nome: caractere
   salario, salarioAumentado: real


Inicio

      Escreval ("Digite o seu nome: ")
      Leia (nome)
      Escreval ("Digite o valor do seu salï¿½rio (reais): ")
      Leia (salario)
      salarioAumentado <- salario + salario * 0.285
      Escreval (nome, ", o seu salï¿½rio ï¿½ de R$ ",salario, " com o acrï¿½scimo de 28,5% passa a ser R$:",salarioAumentado:4:2)


Fimalgoritmo