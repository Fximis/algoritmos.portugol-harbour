Algoritmo "EXC22L01"
// 
//  
// Descriï¿½ï¿½o   : Gere 3 valores aleatï¿½rios e apresente-os em ordem inversa.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
numeroUm, numeroDois, numeroTres: inteiro


Inicio
      Escreval ("Gerador aleatï¿½rio de 03 numeros de 0 a 100 em ordem inversa")
      Escreval (" ")
      
      numeroUm <- randi(100)
      numeroDois <- randi(100)
      numeroTres <- randi(100)


      Escreval ("Os nï¿½meros aleatï¿½rios gerados sï¿½o: ", numeroUm, ",", numeroDois, " e ", numeroTres)
      Escreval (" ")
      Escreval ("Os nï¿½meros aleatï¿½rios em sua ordem inversa sï¿½o: ", numeroTres, ",", numeroDois, " e ", numeroUm)

Fimalgoritmo