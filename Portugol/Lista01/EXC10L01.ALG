Algoritmo "Ex10CalculoVolumeEsfera"
// 
//  
// Descriï¿½ï¿½o   : Calcule e apresente o volume de uma esfera: Volume = (4/3) * 3,1416 * Rï¿½
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
raio, volume: real


Inicio
      Escreva ("Digite o valor do raio da esfera (cm) do prisma: ")
      leia (raio)
      
      volume <- (4/3) * 3.1416 * raio^3
      
      Escreva ("O volume da esfera ï¿½ de ", volume:4:2, "cmï¿½")


Fimalgoritmo