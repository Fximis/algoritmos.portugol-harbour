Algoritmo "EXC21L01"
// 
//  
// Descriï¿½ï¿½o   : Gere 4 valores aleatï¿½rios e apresente os nï¿½meros e a soma total
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
numeroUm, numeroDois, numeroTres, numeroQuatro: inteiro


Inicio
      Escreval ("Gerador aleatï¿½rio de 04 numeros de 0 a 100")
      
      numeroUm <- randi(100)
      numeroDois <- randi(100)
      numeroTres <- randi(100)
      numeroQuatro <- randi(100)

      Escreva ("Os nï¿½meros aleatï¿½rios gerados sï¿½o: ", numeroUm, ",", numeroDois, ",", numeroTres, " e ", numeroQuatro)
               

Fimalgoritmo