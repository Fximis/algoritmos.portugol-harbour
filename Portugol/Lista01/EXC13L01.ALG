Algoritmo "exc13L01"
// 
//  
// Leia 3 nï¿½meros e calcule: (primeiro nï¿½mero + terceiro nï¿½mero) * segundo nï¿½mero
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
valorUm, valorDois, valorTres, resultado: inteiro


Inicio
      Escreva ("Digite o primeiro valor: ")
      Leia (valorUm)
      Escreva ("Digite o segundo valor: ")
      Leia (valorDois)
      Escreva ("Digite o terceiro valor: ")
      Leia (valorTres)
      resultado <- (valorUm + valorTres) * valorDois
      Escreval ("Realizando", valorUm, " + ", valorTres, " e multiplicando pelo", valorDois, " temos", resultado)


Fimalgoritmo