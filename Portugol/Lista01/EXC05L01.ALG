Algoritmo "Ex05CalculoPerimetroCirculo"
// 
//  
// Descriï¿½ï¿½o   : Calcule e apresente o perï¿½metro de um cï¿½rculo: Perï¿½metro = 3,1416 * D, onde D = 2 * R
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
perimetro, raio: real


Inicio
      Escreva ("Digite o valor do raio (cm) do cï¿½rculo: ")
      leia (raio)
      perimetro <- 3.1416 * (raio * 2)
      Escreva ("O valor do perï¿½metro ï¿½ de ", perimetro, "cm")


Fimalgoritmo