Algoritmo "EXC23L01"
// 
//  
// Descriïżœïżœo   : Solicite um valor e apresente 40% desse valor.
// Autor(a)    : Fellipe Miquelïżœo Schmidt 
// Data atual  : 06/08/2025
Var
valor: inteiro
porcentagem_valor: real


Inicio
      Escreval ("Digite um valor: ")
      Leia (valor)
      
      porcentagem_valor <- valor * 0.4


      Escreval ("O valor digitado foi", valor, " sendo 40% deste valor", porcentagem_valor)


Fimalgoritmo