Algoritmo "EXC20L01"
// 
//  
// Descriï¿½ï¿½o   : Solicite 5 nï¿½meros e calcule a mï¿½dia ponderada, com pesos: 2, 4, 2, 5 e 3.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
numeroUm, numeroDois, numeroTres, numeroQuatro, numeroCinco, mediaPonderada: real


Inicio
      Escreva ("Digite 5 nï¿½meros para calcular a mï¿½dia ponderada: ")
      Leia (numeroUm)
      Leia (numeroDois)
      Leia(numeroTres)
      Leia (numeroQuatro)
      Leia  (numeroCinco)
               
      mediaPonderada <- (numeroUm * 2 + numeroDois * 4 + numeroTres * 2 + numeroQuatro * 5 + numeroCinco * 3)/ 2 + 4 + 2 + 5 + 3
      
      Escreval ("A mï¿½dia ponderada ï¿½ de", mediaPonderada)


Fimalgoritmo