Algoritmo "EXC27L01"
// 
//  
// Descriï¿½ï¿½o   : Solicite nome, idade, sexo (M, F ou O) e salï¿½rio de uma pessoa. Calcule e apresente apenas o valor do aumento.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var

idade: inteiro
aumento, salario: real
nome, sexo: caractere

Inicio
      Escreval ("Digite o seu nome: ")
      Leia (nome)
      
      Escreval ("Digite sua idade: ")
      Leia (idade)
      
      Escreval ("Digite seu sexo (M, F, O): ")
      leia (sexo)
      
      Escreval ("Digite seu salario: ")
      Leia (salario)
      
      aumento <- salario * 1.245
      

      Escreval("O salï¿½rio com aumento de 24,5% passa a ser: R$", aumento)


       Fimalgoritmo