Algoritmo "exc11L01"
// 
//  
// Leia 3 notas e calcule a mï¿½dia aritmï¿½tica.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
notaUm, notaDois, notaTres, media: real


Inicio
      Escreva ("Digite o valor da primeira nota: ")
      Leia (notaUm)
      Escreva ("Digite o valor da segunda nota: ")
      Leia (notaDois)
      Escreva ("Digite o valor da terceira nota: ")
      Leia (notaTres)
      Media <- (notaUm + notaDois + notaTres) / 3
      Escreval ("Com base na sua nota de valores", notaUm, ", ", notaDois, " e ", notaTres, " sua mï¿½dia ï¿½", media)


Fimalgoritmo