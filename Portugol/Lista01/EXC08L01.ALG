Algoritmo "Ex08CalculoVolumePiramide"
// 
//  
// Descriï¿½ï¿½o   : Calcule e apresente o volume de uma pirï¿½mide: Volume = (L * L) * (H / 3)
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
altura, largura, volume: real


Inicio
      Escreva ("Digite o valor da largura (cm) da pirï¿½mide: ")
      leia (largura)
      
      Escreva ("Digite o valor da altura da pirï¿½mide (cm): ")
      leia (altura)
      
      volume <- (largura^2) * (altura/3)
      
      Escreva ("O volume da pirï¿½mide ï¿½ de ", volume:4:2, "cmï¿½")


Fimalgoritmo