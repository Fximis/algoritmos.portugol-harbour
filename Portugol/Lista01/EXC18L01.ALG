Algoritmo "exc18L01"
// 
//  
// Solicite um nï¿½mero inteiro e apresente o resto da divisï¿½o por 2 (usar operador MOD ou %).
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var

numeroUm, resto : inteiro


Inicio
      Escreva ("Digite um numero: ")
      leia (numeroUm)
      
      resto <- numeroUm %2
      
      escreval ("o resto da divisï¿½o por 2 ï¿½ ", resto)



Fimalgoritmo