Algoritmo "Ex03AreaTriangulo"
// 
//  
// Descriï¿½ï¿½o   : Calcule e apresente a ï¿½rea de um triï¿½ngulo: ï¿½rea = (base * altura) / 2
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
   base, altura, area: real


Inicio
      Escreval ("======== CALCULO DE ï¿½REA DE UM TRIï¿½NGULO ========")
      Escreva ("Qual a altura do triï¿½ngulo (cm)? ")
      Leia (altura)
      Escreva ("Qual a base do triï¿½ngulo (cm)? ")
      leia (base)
      area <- (base * altura) / 2
      Escreval ("O triï¿½ngulo com", base," cm e ", altura, " cm, possui ï¿½rea de ", area, " cmï¿½")
      

Fimalgoritmo