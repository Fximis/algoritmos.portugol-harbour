Algoritmo "Ex04AreaCirculo"
// 
//  
// Descriï¿½ï¿½o   : Calcule e apresente a ï¿½rea de um cï¿½rculo: ï¿½rea = 3,1416 * Rï¿½ (Rï¿½ significa R * R)
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
raio, area: real


Inicio
      Escreval ("__________ Cï¿½LCULO ï¿½REA DO Cï¿½RCULO __________")
      Escreval ("Qual o raio do cï¿½rculo? (cm)")
      leia (raio)
      area <- 3.1416 * (raio^2)
      Escreva ("O cï¿½rculo possui ï¿½rea de", area, "cmï¿½")


Fimalgoritmo