Algoritmo "exc14L01"
// 
//  
// Leia 2 nï¿½meros e apresente a dï¿½cima parte da subtraï¿½ï¿½o entre eles, usando uma terceira variï¿½vel
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
valorUm, valorDois, subtracao, resultado, decimaParte: real


Inicio
      Escreva ("Digite o primeiro valor: ")
      Leia (valorUm)
      
      Escreva ("Digite o segundo valor: ")
      Leia (valorDois)
      
      subtracao <- (valorUm - valorDois)
      
      decimaParte <- 0.1
      resultado <- (valorUm - ValorDois) * decimaParte
      
      Escreval ("Realizando", valorUm, " - ", valorDois, " temos", subtracao, " sendo a dï¿½cima parte", resultado)


Fimalgoritmo