Algoritmo "exc16L01"
// 
//  
// Leia 5 nï¿½meros fornecidos pelo usuï¿½rio e calcule a soma total.
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 06/08/2025
Var
valorUm, valorDois, valorTres, valorQuatro, valorCinco, resultado: inteiro


Inicio
      Escreval ("Digite cinco valores que queira somar: ")
      Leia (valorUm)
      Leia (valorDois)
      Leia (valorTres)
      Leia (valorQuatro)
      Leia (valorCinco)
      
      resultado <- valorUm + valorDois + valorTres + valorQuatro + valorCinco
      
      Escreval ("Realizando", valorUm, " + ", valorDois, " +", valorTres, " +", valorQuatro, " + ", valorCinco, " temos resulado sendo", resultado)


Fimalgoritmo