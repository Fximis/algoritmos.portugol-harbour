Algoritmo "Ex02DuasVariaveis"
// 
//  
// Descriï¿½ï¿½o   : Leia duas variï¿½veis numï¿½ricas e apresente a soma entre elas, podendo ou nï¿½o armazenar o resultado em uma terceira variavel
// Autor(a)    : Fellipe Miquelï¿½o Schmidt 
// Data atual  : 05/08/2025
Var
   primeiroNumero, segundoNumero, soma: inteiro


Inicio
      Escreva ("Digite um nï¿½mero: ")
      Leia (primeiroNumero)
      Escreva ("Digite outro nï¿½mero: ")
      Leia (segundoNumero)
      soma <- primeiroNumero + segundoNumero
      Escreval ("A soma de ",primeiroNumero, " e ", segundoNumero, " ï¿½", soma)
Fimalgoritmo